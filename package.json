{
  "name": "cold-outreach-engine",
  "version": "1.0.0",
  "description": "End-to-end pipeline for OMG Rentals cold email outbound targeting wedding/event venues",
  "private": true,
  "scripts": {
    "pull": "node 1-prospecting/pull_leads.js",
    "prefilter": "node 2-enrichment/prefilter.js",
    "classify": "python 2-enrichment/classify_batch.py",
    "escalate": "python 2-enrichment/escalate_sonnet.py",
    "phones": "python 2-enrichment/validate_phones.py",
    "export": "node 2-enrichment/export_clean.js",
    "score": "node 2-enrichment/score_leads.js",
    "dedup": "node 1-prospecting/dedup/dedup_geolead.js",
    "dashboards": "node scripts/update-dashboards.js",
    "pipeline": "node pipeline.js run",
    "pipeline:status": "node pipeline.js status",
    "master": "node scripts/build-master.js",
    "master:ghl": "node scripts/build-master.js --export ghl",
    "dashboard": "node scripts/dashboard-server.js",
    "dashboard:refresh": "node scripts/refresh-dashboard.js",
    "dashboard:email": "node scripts/daily-email.js --test",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.5.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  }
}
